{
  "/patrons": {
    "get": {
      "x-mojo-to": "HKS3::PatronNaturalSearch::Controller#search",
      "operationId": "patronNaturalSearch",
      "tags": [
        "patrons"
      ],
      "summary": "Search patrons using MariaDB FULLTEXT indexes",
      "produces": [
        "application/json"
      ],
      "parameters": [
        {
          "name": "query",
          "in": "query",
          "description": "Search term. Aliases q and searchmember are also accepted.",
          "required": false,
          "type": "string"
        },
        {
          "name": "q",
          "in": "query",
          "required": false,
          "type": "string"
        },
        {
          "name": "searchmember",
          "in": "query",
          "required": false,
          "type": "string"
        },
        {
          "name": "searchfieldstype",
          "in": "query",
          "description": "Koha patron search field selector: standard, all, full_address, all_emails, all_phones, a borrower column, an API field alias, or _ATTR_<code>.",
          "required": false,
          "type": "string"
        },
        {
          "name": "search_fields",
          "in": "query",
          "description": "Alias for searchfieldstype. Multiple fields may be separated with | or comma.",
          "required": false,
          "type": "string"
        },
        {
          "name": "match_mode",
          "in": "query",
          "description": "MariaDB FULLTEXT mode. Use boolean to enable MariaDB boolean operators such as a trailing * for prefix matching.",
          "required": false,
          "type": "string",
          "enum": [
            "natural",
            "boolean"
          ]
        },
        {
          "name": "fulltext_mode",
          "in": "query",
          "description": "Alias for match_mode.",
          "required": false,
          "type": "string",
          "enum": [
            "natural",
            "boolean"
          ]
        },
        {
          "name": "boolean_mode",
          "in": "query",
          "description": "Boolean switch alias for match_mode=boolean.",
          "required": false,
          "type": "boolean"
        },
        {
          "name": "searchtype",
          "in": "query",
          "description": "Used only when fallback_like is enabled.",
          "required": false,
          "type": "string",
          "enum": [
            "natural",
            "starts_with",
            "contains"
          ]
        },
        {
          "name": "fallback_like",
          "in": "query",
          "description": "Add SQL LIKE fallback predicates for compatibility with current patron search. MariaDB FULLTEXT scoring is still used for ranking.",
          "required": false,
          "type": "boolean"
        },
        {
          "name": "library_id",
          "in": "query",
          "required": false,
          "type": "string"
        },
        {
          "name": "branchcode_filter",
          "in": "query",
          "required": false,
          "type": "string"
        },
        {
          "name": "category_id",
          "in": "query",
          "required": false,
          "type": "string"
        },
        {
          "name": "categorycode_filter",
          "in": "query",
          "required": false,
          "type": "string"
        },
        {
          "name": "sort1",
          "in": "query",
          "required": false,
          "type": "string"
        },
        {
          "name": "sort1_filter",
          "in": "query",
          "required": false,
          "type": "string"
        },
        {
          "name": "sort2",
          "in": "query",
          "required": false,
          "type": "string"
        },
        {
          "name": "sort2_filter",
          "in": "query",
          "required": false,
          "type": "string"
        },
        {
          "name": "firstletter",
          "in": "query",
          "description": "Restrict results to surnames beginning with this value.",
          "required": false,
          "type": "string"
        },
        {
          "name": "column_cardnumber",
          "in": "query",
          "description": "DataTables column filter for card number.",
          "required": false,
          "type": "string"
        },
        {
          "name": "column_name",
          "in": "query",
          "description": "DataTables column filter for the name/address column.",
          "required": false,
          "type": "string"
        },
        {
          "name": "column_phone",
          "in": "query",
          "description": "DataTables column filter for phone fields.",
          "required": false,
          "type": "string"
        },
        {
          "name": "column_date_of_birth",
          "in": "query",
          "description": "DataTables column filter for date of birth.",
          "required": false,
          "type": "string"
        },
        {
          "name": "column_library",
          "in": "query",
          "description": "DataTables column filter for library/branchcode.",
          "required": false,
          "type": "string"
        },
        {
          "name": "column_category",
          "in": "query",
          "description": "DataTables column filter for patron category.",
          "required": false,
          "type": "string"
        },
        {
          "name": "column_expiry_date",
          "in": "query",
          "description": "DataTables column filter for expiry date.",
          "required": false,
          "type": "string"
        },
        {
          "name": "column_checkouts",
          "in": "query",
          "description": "DataTables column filter for overdues/checkouts count.",
          "required": false,
          "type": "string"
        },
        {
          "name": "column_account_balance",
          "in": "query",
          "description": "DataTables column filter for account balance/fines.",
          "required": false,
          "type": "string"
        },
        {
          "name": "column_staff_notes",
          "in": "query",
          "description": "DataTables column filter for staff notes.",
          "required": false,
          "type": "string"
        },
        {
          "name": "column_statistics_1",
          "in": "query",
          "description": "DataTables column filter for sort 1.",
          "required": false,
          "type": "string"
        },
        {
          "name": "column_statistics_2",
          "in": "query",
          "description": "DataTables column filter for sort 2.",
          "required": false,
          "type": "string"
        },
        {
          "name": "column_attributes",
          "in": "query",
          "description": "DataTables column filter for patron attribute code, description, or value.",
          "required": false,
          "type": "string"
        },
        {
          "name": "page",
          "in": "query",
          "required": false,
          "type": "integer",
          "minimum": 1
        },
        {
          "name": "per_page",
          "in": "query",
          "required": false,
          "type": "integer",
          "minimum": 1,
          "maximum": 100
        },
        {
          "name": "_page",
          "in": "query",
          "required": false,
          "type": "integer",
          "minimum": 1
        },
        {
          "name": "_per_page",
          "in": "query",
          "required": false,
          "type": "integer",
          "minimum": 1,
          "maximum": 100
        },
        {
          "name": "draw",
          "in": "query",
          "description": "DataTables draw counter.",
          "required": false,
          "type": "integer",
          "minimum": 0
        },
        {
          "name": "start",
          "in": "query",
          "description": "DataTables zero-based result offset.",
          "required": false,
          "type": "integer",
          "minimum": 0
        },
        {
          "name": "length",
          "in": "query",
          "description": "DataTables page length.",
          "required": false,
          "type": "integer",
          "minimum": 1,
          "maximum": 100
        },
        {
          "name": "x-koha-embed",
          "in": "header",
          "required": false,
          "description": "Koha REST embeds used by the patron DataTable.",
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "extended_attributes",
              "checkouts+count",
              "overdues+count",
              "account_balance",
              "library"
            ]
          },
          "collectionFormat": "csv"
        }
      ],
      "responses": {
        "200": {
          "description": "Search results",
          "schema": {
            "type": "object",
            "properties": {
              "query": {
                "type": "string"
              },
              "searchfieldstype": {
                "type": "string"
              },
              "search_type": {
                "type": "string"
              },
              "match_mode": {
                "type": "string"
              },
              "fallback_like": {
                "type": "boolean"
              },
              "page": {
                "type": "integer"
              },
              "per_page": {
                "type": "integer"
              },
              "count": {
                "type": "integer"
              },
              "total": {
                "type": "integer"
              },
              "draw": {
                "type": "integer"
              },
              "recordsTotal": {
                "type": "integer"
              },
              "recordsFiltered": {
                "type": "integer"
              },
              "warnings": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "data": {
                "type": "array",
                "items": {
                  "type": "object",
                  "additionalProperties": true
                }
              }
            }
          }
        },
        "401": {
          "description": "Authentication required",
          "schema": {
            "type": "object",
            "additionalProperties": true
          }
        },
        "403": {
          "description": "Access forbidden",
          "schema": {
            "type": "object",
            "additionalProperties": true
          }
        },
        "500": {
          "description": "Search failed",
          "schema": {
            "type": "object",
            "additionalProperties": true
          }
        }
      },
      "x-koha-authorization": {
        "permissions": [
          {
            "borrowers": "list_borrowers"
          },
          {
            "borrowers": "edit_borrowers"
          }
        ]
      }
    }
  }
}
