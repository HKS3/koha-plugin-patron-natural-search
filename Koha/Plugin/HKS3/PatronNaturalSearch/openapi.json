{
  "/patrons": {
    "get": {
      "x-mojo-to": "HKS3::PatronNaturalSearch::Controller#search",
      "operationId": "patronNaturalSearch",
      "tags": [
        "patrons"
      ],
      "summary": "Search patrons using MariaDB FULLTEXT indexes",
      "produces": [
        "application/json"
      ],
      "parameters": [
        {
          "name": "query",
          "in": "query",
          "description": "Search term. Aliases q and searchmember are also accepted.",
          "required": false,
          "type": "string"
        },
        {
          "name": "q",
          "in": "query",
          "required": false,
          "type": "string"
        },
        {
          "name": "searchmember",
          "in": "query",
          "required": false,
          "type": "string"
        },
        {
          "name": "searchfieldstype",
          "in": "query",
          "description": "Koha patron search field selector: standard, all, full_address, all_emails, all_phones, a borrower column, an API field alias, or _ATTR_<code>.",
          "required": false,
          "type": "string"
        },
        {
          "name": "search_fields",
          "in": "query",
          "description": "Alias for searchfieldstype. Multiple fields may be separated with | or comma.",
          "required": false,
          "type": "string"
        },
        {
          "name": "match_mode",
          "in": "query",
          "description": "MariaDB FULLTEXT mode. Use boolean to enable MariaDB boolean operators such as a trailing * for prefix matching.",
          "required": false,
          "type": "string",
          "enum": [
            "natural",
            "boolean"
          ]
        },
        {
          "name": "fulltext_mode",
          "in": "query",
          "description": "Alias for match_mode.",
          "required": false,
          "type": "string",
          "enum": [
            "natural",
            "boolean"
          ]
        },
        {
          "name": "boolean_mode",
          "in": "query",
          "description": "Boolean switch alias for match_mode=boolean.",
          "required": false,
          "type": "boolean"
        },
        {
          "name": "searchtype",
          "in": "query",
          "description": "Used only when fallback_like is enabled.",
          "required": false,
          "type": "string",
          "enum": [
            "natural",
            "starts_with",
            "contains"
          ]
        },
        {
          "name": "fallback_like",
          "in": "query",
          "description": "Add SQL LIKE fallback predicates for compatibility with current patron search. MariaDB FULLTEXT scoring is still used for ranking.",
          "required": false,
          "type": "boolean"
        },
        {
          "name": "library_id",
          "in": "query",
          "required": false,
          "type": "string"
        },
        {
          "name": "branchcode_filter",
          "in": "query",
          "required": false,
          "type": "string"
        },
        {
          "name": "category_id",
          "in": "query",
          "required": false,
          "type": "string"
        },
        {
          "name": "categorycode_filter",
          "in": "query",
          "required": false,
          "type": "string"
        },
        {
          "name": "sort1",
          "in": "query",
          "required": false,
          "type": "string"
        },
        {
          "name": "sort1_filter",
          "in": "query",
          "required": false,
          "type": "string"
        },
        {
          "name": "sort2",
          "in": "query",
          "required": false,
          "type": "string"
        },
        {
          "name": "sort2_filter",
          "in": "query",
          "required": false,
          "type": "string"
        },
        {
          "name": "firstletter",
          "in": "query",
          "description": "Restrict results to surnames beginning with this value.",
          "required": false,
          "type": "string"
        },
        {
          "name": "page",
          "in": "query",
          "required": false,
          "type": "integer",
          "minimum": 1
        },
        {
          "name": "per_page",
          "in": "query",
          "required": false,
          "type": "integer",
          "minimum": 1,
          "maximum": 100
        },
        {
          "name": "_page",
          "in": "query",
          "required": false,
          "type": "integer",
          "minimum": 1
        },
        {
          "name": "_per_page",
          "in": "query",
          "required": false,
          "type": "integer",
          "minimum": 1,
          "maximum": 100
        }
      ],
      "responses": {
        "200": {
          "description": "Search results",
          "schema": {
            "type": "object",
            "properties": {
              "query": {
                "type": "string"
              },
              "searchfieldstype": {
                "type": "string"
              },
              "search_type": {
                "type": "string"
              },
              "match_mode": {
                "type": "string"
              },
              "fallback_like": {
                "type": "boolean"
              },
              "page": {
                "type": "integer"
              },
              "per_page": {
                "type": "integer"
              },
              "count": {
                "type": "integer"
              },
              "total": {
                "type": "integer"
              },
              "warnings": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "data": {
                "type": "array",
                "items": {
                  "type": "object",
                  "additionalProperties": true
                }
              }
            }
          }
        },
        "401": {
          "description": "Authentication required",
          "schema": {
            "type": "object",
            "additionalProperties": true
          }
        },
        "403": {
          "description": "Access forbidden",
          "schema": {
            "type": "object",
            "additionalProperties": true
          }
        },
        "500": {
          "description": "Search failed",
          "schema": {
            "type": "object",
            "additionalProperties": true
          }
        }
      },
      "x-koha-authorization": {
        "permissions": [
          {
            "borrowers": "list_borrowers"
          },
          {
            "borrowers": "edit_borrowers"
          }
        ]
      }
    }
  }
}
